# Company-provided key (required for LLM routing/tools)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5
PARAMEDIC_NAME=

# Optional email delivery settings for Teddy Bear form artifacts
TARGET_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# MongoDB settings for short-term chat memory storage
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=paramedic_ai
MONGODB_SHORT_TERM_COLLECTION=short_term
